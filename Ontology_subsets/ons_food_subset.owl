    <!-- http://purl.obolibrary.org/obo/BFO_0000040 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000040">
        <obo:IAO_0000111 xml:lang="en">material entity</obo:IAO_0000111>
        <obo:IAO_0000115>An independent continuant that is spatially extended whose identity is independent of that of other entities and can be maintained through time.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">An independent continuant that is spatially extended whose identity is independent of that of other entities and can be maintained through time.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Elucidation: An independent continuant that is spatially extended whose identity is independent of that of other entities and can be maintained through time.</obo:IAO_0000116>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/cob.owl"/>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/envo.owl"/>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/foodon.owl"/>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/iao.owl"/>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/obi.owl"/>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/ohmi.owl"/>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/po.owl"/>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/stato.owl"/>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/vo.owl"/>
        <obo:IAO_0000412 rdf:resource="http://www.ebi.ac.uk/efo/efo.owl"/>
        <rdfs:label>material entity</rdfs:label>
        <rdfs:label xml:lang="en">material entity</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00001002 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001002">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00002403"/>
        <obo:IAO_0000115 xml:lang="en">Food material for humans and animals which is processed with the intention that it be consumable as a whole or added to other food products.</obo:IAO_0000115>
        <obo:IAO_0000119 rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://en.wikipedia.org/wiki/Food</obo:IAO_0000119>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/foodon.owl"/>
        <rdfs:label xml:lang="en">food product</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00001015 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001015">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00001002"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_03420116"/>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000122"/>
        <obo:IAO_0000115 xml:lang="en">A food product which has as a defining ingredient some plant material.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/foodon.owl"/>
        <rdfs:label xml:lang="en">plant food product</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00001046 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001046">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00004242"/>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000428"/>
        <obo:IAO_0000115 xml:lang="en">A seafood product is a vertebrate or invertibrate organism from an aquatic environment.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/foodon.owl"/>
        <rdfs:label xml:lang="en">animal seafood product</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00001143 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001143">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00001002"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_03420116"/>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000122"/>
        <obo:IAO_0000115 xml:lang="en">A food product consisting of an edible fungi or mushroom or yeast.</obo:IAO_0000115>
        <obo:IAO_0000119 rdf:resource="https://en.wikipedia.org/wiki/Fungus#In_food"/>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/foodon.owl"/>
        <rdfs:label xml:lang="en">fungus food product</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00001184 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001184">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_03420116"/>
        <obo:IAO_0000115 xml:lang="en">Material which derives from algae (including single-celled microalgae and  multicellular macroalgae).</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/foodon.owl"/>
        <rdfs:label xml:lang="en">algae material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00001248 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001248">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00004242"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_03420164"/>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000122"/>
        <obo:IAO_0000115 xml:lang="en">A fish food product includes products made from any fish species (aquatic vertebrate with gills and fins).</obo:IAO_0000115>
        <obo:IAO_0000119 rdf:resource="https://en.wikipedia.org/wiki/Fish"/>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/foodon.owl"/>
        <rdfs:label xml:lang="en">fish food product</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00002403 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00002403">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <obo:IAO_0000115 xml:lang="en">Any substance that can be consumed by an organism to satisfy nutritional or other health needs, or to provide a social or organoleptic food experience</obo:IAO_0000115>
        <obo:IAO_0000119 rdf:resource="https://en.wikipedia.org/wiki/Food"/>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/foodon.owl"/>
        <oboInOwl:hasExactSynonym xml:lang="en">food</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">foodstuff</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">food material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00003194 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00003194">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00002403"/>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000122"/>
        <obo:IAO_0000115 xml:lang="en">A food product not including meat and animal tissue products (such as gelatin or animal-derived rennet).</obo:IAO_0000115>
        <obo:IAO_0000119 xml:lang="en">https://en.wikipedia.org/wiki/Vegetarian_cuisine</obo:IAO_0000119>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/foodon.owl"/>
        <oboInOwl:hasExactSynonym xml:lang="en">vegetarian food</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">vegetarian food material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00004242 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00004242">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00001002"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_03420164"/>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000122"/>
        <obo:IAO_0000115 xml:lang="en">A food product that is derived from some animal.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/foodon.owl"/>
        <rdfs:label xml:lang="en">animal food product</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_03420116 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FOODON_03420116">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000428"/>
        <obo:IAO_0000115 xml:lang="en">Material which is distinguished primarily by the organism(s) it derives from.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/foodon.owl"/>
        <rdfs:label xml:lang="en">organism material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_03420164 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FOODON_03420164">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_03420116"/>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000122"/>
        <obo:IAO_0000115 xml:lang="en">Material that derives from one or more animals</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/foodon.owl"/>
        <rdfs:label xml:lang="en">animal material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ONS_0000082 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ONS_0000082">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ONS_1000007"/>
        <obo:IAO_0000115 xml:lang="en">A diet prescribed by a physician/ nutritionist to meet specific nutritional needs of a person.</obo:IAO_0000115>
        <obo:IAO_0000117>ENPADASI_WP4</obo:IAO_0000117>
        <obo:IAO_0000117>https://github.com/FoodOntology/joint-food-ontology-wg</obo:IAO_0000117>
        <oboInOwl:hasExactSynonym xml:lang="en">clinical treatment protocol</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">diet therapy</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">dietetic diet</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">medically proscribed diet</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">clinically prescribed diet</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ONS_1000001 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ONS_1000001">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00002403"/>
        <obo:IAO_0000115 xml:lang="en">A collection of food types or items which have organoleptic, nutritional, availability, safety, meal time, or socially relevant characteristics with respect to a consuming individual or population.</obo:IAO_0000115>
        <obo:IAO_0000117>https://github.com/FoodOntology/joint-food-ontology-wg</obo:IAO_0000117>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/Diet_(nutrition)</obo:IAO_0000119>
        <oboInOwl:hasDbXref>http://id.nlm.nih.gov/mesh/D004032</oboInOwl:hasDbXref>
        <rdfs:comment xml:lang="en">OLD definition: In nutrition, diet is the sum of food consumed by a person or other organism</rdfs:comment>
        <rdfs:label xml:lang="en">diet</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ONS_1000005 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ONS_1000005">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ONS_1000001"/>
        <obo:IAO_0000115 xml:lang="en">A diet defined by the nutritional presence or absence of types of food bioactive compounds.</obo:IAO_0000115>
        <obo:IAO_0000117>https://github.com/FoodOntology/joint-food-ontology-wg</obo:IAO_0000117>
        <rdfs:label xml:lang="en">diet by nutritional composition</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ONS_1000007 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ONS_1000007">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ONS_1000001"/>
        <obo:IAO_0000115 xml:lang="en">A diet which is prescribed to meet some dietary pattern objective for an individual organism or group.</obo:IAO_0000115>
        <obo:IAO_0000117>https://github.com/FoodOntology/joint-food-ontology-wg</obo:IAO_0000117>
        <rdfs:label xml:lang="en">prescribed diet</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ONS_1000019 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ONS_1000019">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ONS_1000001"/>
        <obo:IAO_0000115 xml:lang="en">A diet defined by the food source organisms it allows or excludes.</obo:IAO_0000115>
        <obo:IAO_0000117>https://github.com/FoodOntology/joint-food-ontology-wg</obo:IAO_0000117>
        <rdfs:label xml:lang="en">diet by food organism</rdfs:label>
    </owl:Class>
    


