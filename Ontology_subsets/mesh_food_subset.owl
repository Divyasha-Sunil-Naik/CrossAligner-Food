        <skos:altLabel xml:lang="en">Community Health</skos:altLabel>
        <skos:altLabel xml:lang="en">Environment, Preventive Medicine &amp; Public Health</skos:altLabel>
        <skos:altLabel xml:lang="en">Environment, Preventive Medicine and Public Health</skos:altLabel>
        <skos:altLabel xml:lang="en">Health, Community</skos:altLabel>
        <skos:altLabel xml:lang="en">Health, Public</skos:altLabel>
        <skos:definition xml:lang="en">Branch of medicine concerned with the prevention and control of disease and disability, and the promotion of physical and mental health of the population on the international, national, state, or municipal level.</skos:definition>
        <skos:prefLabel xml:lang="en">Public Health</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.bioontology.org/ontology/MESH/D013676 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/MESH/D013676">
        <umls:cui>C0039426</umls:cui>
        <umls:tui>T078</umls:tui>
        <skos:definition xml:lang="en">The science and application of techniques for the extraction of raw materials, provision of services, manufacture of goods, cultivation of crops, and raising of livestock.</skos:definition>
        <skos:prefLabel xml:lang="en">Technology, Industry, and Agriculture</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.bioontology.org/ontology/MESH/D019649 -->

