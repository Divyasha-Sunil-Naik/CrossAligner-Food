        <umls:cui>C0014407</umls:cui>
        <umls:tui>T091</umls:tui>
        <skos:definition xml:lang="en">Natural and man-made environments and their impact on public health.</skos:definition>
        <skos:prefLabel xml:lang="en">Environment and Public Health</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.bioontology.org/ontology/MESH/D005506 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/MESH/D005506">
        <rdfs:subClassOf rdf:resource="http://purl.bioontology.org/ontology/MESH/D011634"/>
        <rdfs:subClassOf rdf:resource="http://purl.bioontology.org/ontology/MESH/D063427"/>
        <umls:cui>C0016454</umls:cui>
        <umls:cui>C0016462</umls:cui>
        <umls:tui>T067</umls:tui>
        <umls:tui>T068</umls:tui>
        <skos:altLabel xml:lang="en">Adulteration, Food</skos:altLabel>
        <skos:altLabel xml:lang="en">Adulterations, Food</skos:altLabel>
        <skos:altLabel xml:lang="en">Contamination, Food</skos:altLabel>
        <skos:altLabel xml:lang="en">Contaminations, Food</skos:altLabel>
        <skos:altLabel xml:lang="en">Food Adulteration</skos:altLabel>
        <skos:altLabel xml:lang="en">Food Adulterations</skos:altLabel>
        <skos:altLabel xml:lang="en">Food Contaminations</skos:altLabel>
        <skos:definition xml:lang="en">The presence in food of harmful, unpalatable, or otherwise objectionable foreign substances, e.g. chemicals, microorganisms or diluents, before, during, or after processing or storage.</skos:definition>
        <skos:prefLabel xml:lang="en">Food Contamination</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.bioontology.org/ontology/MESH/D005515 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/MESH/D005515">
