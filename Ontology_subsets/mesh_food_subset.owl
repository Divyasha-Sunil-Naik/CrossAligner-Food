        <skos:altLabel xml:lang="en">Industry, Food</skos:altLabel>
        <skos:definition xml:lang="en">The industry concerned with processing, preparing, preserving, distributing, and serving of foods and beverages.</skos:definition>
        <skos:prefLabel xml:lang="en">Food Industry</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.bioontology.org/ontology/MESH/D063427 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/MESH/D063427">
