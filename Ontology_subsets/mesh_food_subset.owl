        <skos:altLabel xml:lang="en">Population Statistics</skos:altLabel>
        <skos:altLabel xml:lang="en">Statistics, Population</skos:altLabel>
        <skos:definition xml:lang="en">Qualities and characterization of various types of populations within a social or geographic group, with emphasis on demography, health status, and socioeconomic factors.</skos:definition>
        <skos:prefLabel xml:lang="en">Population Characteristics</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.bioontology.org/ontology/MESH/D011634 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/MESH/D011634">
