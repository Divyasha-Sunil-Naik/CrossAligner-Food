        <umls:cui>C0016475</umls:cui>
        <umls:cui>C0028711</umls:cui>
        <umls:tui>T057</umls:tui>
        <umls:tui>T068</umls:tui>
        <skos:altLabel xml:lang="en">Food Labelling</skos:altLabel>
        <skos:altLabel xml:lang="en">Food Product Labeling</skos:altLabel>
        <skos:altLabel xml:lang="en">Labeling, Food</skos:altLabel>
        <skos:altLabel xml:lang="en">Labeling, Food Product</skos:altLabel>
        <skos:altLabel xml:lang="en">Labeling, Nutrition</skos:altLabel>
        <skos:altLabel xml:lang="en">Labelling, Food</skos:altLabel>
        <skos:altLabel xml:lang="en">Nutrition Labeling</skos:altLabel>
        <skos:altLabel xml:lang="en">Product Labeling, Food</skos:altLabel>
        <skos:definition xml:lang="en">Use of written, printed, or graphic materials upon or accompanying a food or its container or wrapper. The concept includes ingredients, NUTRITIONAL VALUE, directions, warnings, and other relevant information.</skos:definition>
        <skos:prefLabel xml:lang="en">Food Labeling</skos:prefLabel>
    </owl:Class>
    


